#!/bin/bash

alias ..="cd ../"
alias ...="cd ../.."
alias ....="cd ../../.."

alias :q="exit"
alias ch="history -c && > ~/.bash_history"
alias dot="code ~/dotfiles"
alias dotsync="~/.auto_sync.sh"
alias dotgpn="~/.auto_sync_gpr.sh"
alias dothub="~/.auto_sync_hub.sh"
alias e="vim --"
alias g="git"
alias ghqp="ghq list | ghq get --update --parallel"
alias gr="cd-gitroot"
alias gom="g o master && g ull"
alias gpd="git publish && hpd"
alias gpn="git publish && hpn"
alias gpo="git publish && hpo"
alias hpd="hub pull-request -d"
alias hpn="hub pull-request --no-edit"
alias hpo="hub pull-request -o"
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias ls="lsd"
alias m="man"
alias map="xargs -n1"
alias mux="tmuxinator"
alias path='printf "%b\n" "${PATH//:/\\n}"'
alias reload="source ~/.zshrc"
alias q="exit"
alias rm="rm -rf --"
alias sk="shunkakinoki"
alias t="tmux"
alias y="yarn"
