#!/bin/bash

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias cd..="cd .."

alias :q="exit"
alias ch="history -c && > ~/.bash_history"
alias e="vim --"
alias g="git"
alias gr="cd-gitroot"
alias gprn="g publish && hprn"
alias gpro="g publish && hpro"
alias hprn="hub pull-request --no-edit"
alias hpro="hub pull-request -o"
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias ls="lsd"
alias m="man"
alias map="xargs -n1"
alias mux="tmuxinator"
alias path='printf "%b\n" "${PATH//:/\\n}"'
alias reload="source ~/.zshrc"
alias q="exit"
alias rm="rm -rf --"
alias t="tmux"
alias y="yarn"
