#!/bin/bash

alias ..="cd ../"
alias ...="cd ../.."
alias ....="cd ../../.."

alias :q="exit"
alias awsp="source _awsp"
alias ch="history -c && > ~/.bash_history"
alias codeon="mkdir -p ~/.ghqlist && ghq list -p > ~/.ghqlist/enhancd.log && export ENHANCD_DIR=~/.ghqlist"
alias codeoff="export ENHANCD_DIR=~/.enhancd"
alias dot="code ~/dotfiles"
alias dotsync="~/.auto_sync.sh"
alias dotgpn="~/.auto_sync_gpr.sh"
alias dothub="~/.auto_sync_hub.sh"
alias e="vim --"
alias g="git"
alias ghqp="ghq list | ghq get --update --parallel"
alias gr="cd-gitroot"
alias goa="g o alpha && g ull"
alias gob="g o beta && g ull"
alias gom="g o main && g ull"
alias gpa="git publish && gpra"
alias gpb="git publish && gprb"
alias gpd="git publish && gprd"
alias gpn="git publish && gprn"
alias gpo="git publish && gpro"
alias gpra="gh pr create --base alpha --fill"
alias gprb="gh pr create --base beta --fill"
alias gprd="gh pr create --draft"
alias gprn="gh pr create --base main --fill"
alias gpro="gh pr create -o"
alias idot="code-insiders ~/dotfiles"
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias ls="lsd"
alias m="man"
alias map="xargs -n1"
alias mux="tmuxinator"
alias path='printf "%b\n" "${PATH//:/\\n}"'
alias pti="~/.tmux/plugins/tpm/scripts/install_plugins.sh"
alias pvi="vim +'PlugInstall --sync' +qa"
alias reload="source ~/.zshrc"
alias q="exit"
alias rm="rm -rf --"
alias sk="shunkakinoki"
alias t="tmux attach || tmux new"
alias y="yarn"
