#!/bin/bash

### UNIQUE PATHS
export GOPATH="$HOME/.go"
export GOBIN="$GOPATH/bin"
export PYENV_ROOT="$HOME/.pyenv"

### PATHS
export HOME="$HOME"
export PATH="$HOME/.pyenv/shims:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/n/bin:$HOME/.poetry/bin:/usr/lib/google-cloud-sdk/bin:$HOME/.pub-cache/bin:$HOME/dotfiles/src/bundle/vendor/bundle/ruby/2.6.0/bin:$HOME/dotfiles/src/pipenv/.venv/bin:$HOME/dotfiles/src/yarn/node_modules/.bin:$HOME/.cargo/bin:$HOME/.cargo/env:$HOME/flutter/bin:$HOME/.fastlane/bin:$HOME/.rvm/bin"

source /usr/local/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc
source /usr/local/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc
