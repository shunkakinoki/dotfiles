id=$(printf '%s' \"$line\" | cut -d' ' -f4)\n      tmux capture-pane -pt \"$pane_id\" -S - 2>/dev/null \\\n        > \"$PANE_DIR/$sess--$widx--$pidx.txt\"\n    done\n\n  # For each .old: if a live .txt exists → pane survived → delete .old\n  #                if no live .txt  → pane closed  → archive with timestamp\n  ts=$(date +%Y%m%d-%H%M%S)\n  for old in \"$PANE_DIR\"/*.old; do\n    [ -f \"$old\" ] || continue\n    base=$(basename \"${old%.old}\")\n    if [ -f \"$PANE_DIR/$base.txt\" ]; then\n      rm -f \"$old\"\n    else\n      mv \"$old\" \"$ARCHIVE_DIR/${base}--${ts}.txt\"\n    fi\n  done\ndone\n```\n\n---\n\n### 2. Update `_tsh_function.fish` — search archive too\n\n**File:** `home-manager/programs/fish/functions/_tsh_function.fish`\n\n- Add `archive_dir` variable pointing at `~/.local/share/tmux/archive`\n- Pass both `$pane_dir` and `$archive_dir` to `rg -l` so search covers live + closed panes\n- Parse filenames from archive: `work--0--0--20260226-103000.txt` → sess=`work`, widx=`0`\n  - Strip the trailing `--<timestamp>` before splitting on `--`\n  - Since archived panes no longer exist, skip the `tmux has-session` jump and instead just print the file path / preview content\n\nThe archive filename format `sess--widx--pidx--YYYYMMDD-HHMMSS.txt` lets us extract `parts[1]` and `parts[2]` the same way as live files. For dead sessions, we print a message but still show the content.\n\n```fish\nfunction _tsh_function --description \"Search tmux session history log or pane contents\"\n  set -l log ~/.local/share/tmux/session-history.log\n  set -l pane_dir ~/.local/share/tmux/panes\n  set -l archive_dir ~/.local/share/tmux/archive\n\n  if test (count $argv) -gt 0\n    if not test -d \"$pane_dir\"\n      echo \"No pane content store found at $pane_dir\"\n      return\n    end\n\n    set -l query (string join ' ' $argv)\n    set -l selected (rg -l -- \"$query\" \"$pane_dir\" \"$archive_dir\" 2>/dev/null \\\n      | fzf --prompt=\"pane-search> \" \\\n            --he