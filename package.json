{
  "name": "@shunkakinoki/dotfiles",
  "version": "3.21.0",
  "homepage": "https://github.com/shunkakinoki/dotfiles",
  "repository": {
    "type": "git",
    "url": "https://github.com/shunkakinoki/dotfiles.git"
  },
  "license": "MIT",
  "author": "Shun Kakinoki",
  "scripts": {
    "check": "yarn run lint && yarn run depcheck:check && yarn run release:check",
    "depcheck:check": "yarn run depcheck:exec && yarn run depcheck:root",
    "depcheck:exec": "yarn workspaces run depcheck .",
    "depcheck:root": "depcheck . --skip-missing=true",
    "eslint:lint": "",
    "eslint:fix": "",
    "fix": "concurrently 'yarn:*:fix'",
    "lint": "concurrently 'yarn:*:lint'",
    "ncu:check": "ncu --deep -p yarn",
    "ncu:upgrade": "ncu --deep -u -p yarn",
    "npm-package-json:lint": "npmPkgJsonLint .",
    "postpublish": "pinst --enable",
    "prepublishOnly": "pinst --disable",
    "prettier:lint": "prettier --check . --ignore-unknown",
    "prettier:fix": "prettier --write . --ignore-unknown",
    "prepare": "husky install",
    "release": "yarn run semantic-release",
    "release:check": "yarn run semantic-release:check",
    "semantic-release": "semantic-release",
    "semantic-release:check": "semantic-release --dry-run",
    "sort-package-json:lint": "sort-package-json 'package.json'",
    "sort-package-json:fix": "sort-package-json 'package.json'"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^5.0.1",
    "@semantic-release/exec": "^5.0.0",
    "@semantic-release/git": "^9.0.0",
    "commitizen": "^4.2.1",
    "depcheck": "^1.2.0",
    "git-cz": "^4.7.1",
    "husky": "^4.3.0",
    "json-sort-cli": "^1.15.27",
    "npm-check-updates": "^9.0.2",
    "prettier": "^2.1.1",
    "semantic-release": "^17.1.1",
    "sort-package-json": "^1.44.0"
  }
}
